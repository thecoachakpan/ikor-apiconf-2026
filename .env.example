# --- Supabase Database & Auth (Required for User Session & Settings) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Gemini API (Optional Fallback ASR & Polishing engine) ---
VITE_GEMINI_API_KEY=your-gemini-api-key

# --- Paystack Payment Gateway (For Upgrades and Top-Ups) ---
VITE_PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# --- Monnify API Configuration (For Sandbox Payments & local MCP Server) ---
# Note: These are optional here if you configure them directly in the app's Settings -> MCP Server tab.
VITE_MONNIFY_API_KEY=your-monnify-sandbox-api-key
VITE_MONNIFY_SECRET_KEY=your-monnify-sandbox-secret-key
VITE_MONNIFY_CONTRACT_CODE=your-monnify-contract-code
