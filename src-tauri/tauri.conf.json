{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sayikor",
  "version": "0.1.18",
  "identifier": "sayikor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "Sayikor Dashboard",
        "width": 1024,
        "height": 768,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "shadow": true,
        "skipTaskbar": false,
        "visible": false,
        "userAgent": "Sayikor/1.0"
      },
      {
        "label": "bubble",
        "title": "Speech Bubble",
        "width": 320,
        "height": 60,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "userAgent": "Sayikor/1.0"
      },
      {
        "label": "approval",
        "title": "Approval Panel",
        "width": 520,
        "height": 420,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "userAgent": "Sayikor/1.0"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
